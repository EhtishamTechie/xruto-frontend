# Frontend Environment Configuration
# Copy this file to .env and fill in your actual values

# ===========================================
# API CONFIGURATION
# ===========================================
# Backend API URL
# For local development:
VITE_API_URL=http://localhost:5000/api

# For production, update to:
# VITE_API_URL=https://your-backend-domain.com/api

# Only if you use an old backend without GET /api/orders/analytics-snapshot. Using this
# may freeze the tab when /orders/get-routes returns a large JSON (not recommended).
# VITE_LEGACY_ANALYTICS=true

# ===========================================
# NOTES FOR CLIENT TESTING
# ===========================================
# This URL points to your local backend server
# Ensure backend is running on port 5000
# No changes needed for initial testing
