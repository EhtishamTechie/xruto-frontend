# =============================================================================
# xRuto frontend (Vite) — copy to .env or .env.local
# Build-time: VITE_* are baked in at `npm run build`. Set them in Vercel → Settings → Environment Variables.
# =============================================================================

# Backend API base (must include /api)
# Local:
VITE_API_URL=http://localhost:5000/api
# Production (Render web service URL):
# VITE_API_URL=https://your-service.onrender.com/api

# Analytics: keep false unless you use an old backend without GET /api/orders/analytics-snapshot
# VITE_LEGACY_ANALYTICS=false

# Optional PWA push (only if you configure service worker keys)
# VITE_VAPID_PUBLIC_KEY=
